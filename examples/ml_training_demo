        {
            "cell_type": "markdown",
            "metadata": {},
            "source": ["## 2. Feature Engineering"]
        },
        {
            "cell_type": "code",
            "execution_count": None,
            "metadata": {},
            "outputs": [],
            "source": [
                "def add_features(df):\n",
                "    df = df.copy()\n",
                "    \n",
                "    df['returns'] = df['close'].pct_change()\n",
                "    df['log_returns'] = np.log(df['close'] / df['close'].shift(1))\n",
                "    \n",
                "    df['sma_10'] = df['close'].rolling(10).mean()\n",
                "    df['sma_30'] = df['close'].rolling(30).mean()\n",
                "    df['ema_10'] = df['close'].ewm(span=10).mean()\n",
                "    \n",
                "    df['atr'] = (df['high'] - df['low']).rolling(14).mean()\n",
                "    df['volatility'] = df['returns'].rolling(24).std() * np.sqrt(24)\n",
                "    \n",
                "    df['close_to_high'] = (df['close'] - df['low']) / (df['high'] - df['low'] + 1e-10)\n",
                "    df['close_to_sma10'] = df['close'] / df['sma_10'] - 1\n",
                "    \n",
                "    df['volume_sma'] = df['volume'].rolling(24).mean()\n",
                "    df['volume_ratio'] = df['volume'] / df['volume_sma']\n",
                "    \n",
                "    for lag in [1, 2, 3, 5, 10]:\n",
                "        df[f'close_lag_{lag}'] = df['close'].shift(lag)\n",
                "        df[f'returns_lag_{lag}'] = df['returns'].shift(lag)\n",
                "    \n",
                "    df['target_return'] = df['close'].shift(-5) / df['close'] - 1\n",
                "    df['target_direction'] = (df['target_return'] > 0).astype(int)\n",
                "    \n",
                "    return df.dropna()\n",
                "\n",
                "df_features = add_features(df)\n",
                "print(f'Features shape: {df_features.shape}')\n",
                "feature_cols = [c for c in df_features.columns if 'lag' in c or c in [\n",
                "    'returns', 'volatility', 'close_to_high', 'close_to_sma10', 'volume_ratio', 'atr'\n",
                "]\n",
                "print(f'Feature columns: {len(feature_cols)}')\n",
                "df_features.head()"
            ]
        },
