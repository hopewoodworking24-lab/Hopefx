            "source": [
                "def generate_xauusd_data(days=180, start_price=2000.0):\n",
                "    data = []\n",
                "    price = start_price\n",
                "    start_date = datetime(2024, 1, 1)\n",
                "    \n",
                "    for day in range(days):\n",
                "        date = start_date + timedelta(days=day)\n",
                "        if date.weekday() >= 5:\n",
                "            continue\n",
                "        \n",
                "        for hour in range(24):\n",
                "            change = np.random.normal(0.05, 1.2)\n",
                "            price = max(1800, min(2200, price + change))\n",
                "            \n",
                "            volatility = abs(np.random.normal(0, 0.8))\n",
                "            open_p = price - np.random.normal(0, 0.3)\n",
                "            high_p = max(open_p, price) + volatility * 0.5\n",
                "            low_p = min(open_p, price) - volatility * 0.5\n",
                "            close_p = price\n",
                "            volume = np.random.randint(1000, 15000)\n",
                "            \n",
                "            data.append({\n",
                "                'timestamp': date.replace(hour=hour),\n",
                "                'open': round(open_p, 2),\n",
                "                'high': round(high_p, 2),\n",
                "                'low': round(low_p, 2),\n",
                "                'close': round(close_p, 2),\n",
                "                'volume': volume\n",
                "            })\n",
                "    \n",
                "    return pd.DataFrame(data)\n",
                "\n",
                "df = generate_xauusd_data(days=180)\n",
                "print(f'Generated {len(df)} hourly candles')\n",
                "print(f'Date range: {df[\"timestamp\"].min()} to {df[\"timestamp\"].max()}')\n",
                "df.head()"
            ]
