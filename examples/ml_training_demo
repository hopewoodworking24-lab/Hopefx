            "source": [
                "try:\n",
                "    import tensorflow as tf\n",
                "    from tensorflow.keras.models import Sequential\n",
                "    from tensorflow.keras.layers import LSTM, Dense, Dropout\n",
                "    from sklearn.preprocessing import MinMaxScaler\n",
                "    \n",
                "    tf.random.set_seed(42)\n",
                "    \n",
                "    def create_sequences(data, seq_length=20):\n",
                "        X, y = [], []\n",
                "        for i in range(len(data) - seq_length):\n",
                "            X.append(data[i:i+seq_length])\n",
                "            y.append(data[i+seq_length, 0])\n",
                "        return np.array(X), np.array(y)\n",
                "    \n",
                "    scaler = MinMaxScaler()\n",
                "    X_scaled = scaler.fit_transform(X)\n",
                "    \n",
                "    seq_length = 20\n",
                "    X_seq, y_seq = create_sequences(X_scaled, seq_length)\n",
                "    split = int(len(X_seq) * 0.8)\n",
                "    X_lstm_train, X_lstm_test = X_seq[:split], X_seq[split:]\n",
                "    y_lstm_train, y_lstm_test = y_seq[:split], y_seq[split:]\n",
                "    \n",
                "    model = Sequential([\n",
                "        LSTM(50, return_sequences=True, input_shape=(seq_length, X.shape[1])),\n",
                "        Dropout(0.2),\n",
                "        LSTM(50, return_sequences=False),\n",
                "        Dropout(0.2),\n",
                "        Dense(25),\n",
                "        Dense(1)\n",
                "    ])\n",
                "    model.compile(optimizer='adam', loss='mse')\n",
                "    \n",
                "    history = model.fit(\n",
                "        X_lstm_train, y_lstm_train,\n",
                "        epochs=20, batch_size=32, validation_split=0.2, verbose=1\n",
                "    )\n",
                "    \n",
                "    plt.figure(figsize=(10, 4))\n",
                "    plt.plot(history.history['loss'], label='Train Loss')\n",
                "    plt.plot(history.history['val_loss'], label='Val Loss')\n",
                "    plt.title('LSTM Training History')\n",
                "    plt.legend()\n",
                "    plt.savefig('../results/lstm_training_history.png', dpi=150)\n",
                "    plt.show()\n",
                "    \n",
                "    y_pred_lstm = model.predict(X_lstm_test)\n",
                "    plt.figure(figsize=(12, 5))\n",
                "    plt.plot(y_lstm_test[:100], label='Actual')\n",
                "    plt.plot(y_pred_lstm[:100], label='Predicted')\n",
                "    plt.title('LSTM Predictions vs Actual')\n",
                "    plt.legend()\n",
                "    plt.savefig('../results/lstm_predictions.png', dpi=150)\n",
                "    plt.show()\n",
                "    \n",
