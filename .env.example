# HOPEFX AI TRADING FRAMEWORK
# Configuration Template - Copy to .env and fill in your credentials

# ==================== BROKER APIs ====================
# OANDA Configuration
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=v20  # or practice

# MetaTrader 5 Configuration
MT5_LOGIN=your_mt5_login_here
MT5_PASSWORD=your_mt5_password_here
MT5_SERVER=your_mt5_server_here
MT5_ACCOUNT_TYPE=real  # or demo

# Interactive Brokers Configuration
IB_ACCOUNT_ID=your_ib_account_id_here
IB_API_PORT=7497

# ==================== DATABASE ====================
# SQLite Configuration (Development)
SQLITE_DB_PATH=./data/hopefx_trading.db

# PostgreSQL Configuration (Production)
POSTGRES_USER=hopefx_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hopefx_trading

# Database Security (Production MUST enable SSL/TLS)
DB_SSL_ENABLED=true
DB_SSL_MODE=require  # disable, allow, prefer, require, verify-ca, verify-full
DB_SSL_CERT_PATH=./credentials/db-client-cert.pem
DB_SSL_KEY_PATH=./credentials/db-client-key.pem
DB_SSL_CA_PATH=./credentials/db-ca-cert.pem

DB_TYPE=sqlite  # or postgresql

# ==================== AI & ML ====================
# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo

# Claude API Configuration
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-opus-20240229

AI_PROVIDER=openai  # or claude

# ==================== MARKET DATA ====================
# News API
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage API (for news and market data)
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Economic Calendar (FRED API)
FRED_API_KEY=your_fred_api_key_here

# ==================== GEOPOLITICAL INTELLIGENCE ====================
# World Monitor Integration (https://worldmonitor.app/)
# Open-source geopolitical intelligence dashboard for trading risk assessment
WORLDMONITOR_ENABLED=true
WORLDMONITOR_TIME_RANGE=7d  # 1h, 6h, 24h, 48h, 7d
WORLDMONITOR_CACHE_TTL=300  # Cache TTL in seconds
WORLDMONITOR_DATA_LAYERS=conflicts,hotspots,sanctions,weather,outages,natural

# Geopolitical Risk Thresholds for Gold Trading
GEOPOLITICAL_HIGH_RISK_THRESHOLD=70  # Global risk score to trigger alerts
GEOPOLITICAL_GOLD_BIAS_WEIGHT=0.3  # Weight of geopolitical signal in trading

# Telegram/Discord for Sentiment
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==================== NOTIFICATIONS ====================
# Discord Integration
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Telegram Integration
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email Configuration
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password_here
EMAIL_RECIPIENTS=recipient1@email.com,recipient2@email.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ==================== TRADING PARAMETERS ====================
# Risk Management
DAILY_LOSS_LIMIT=500  # USD
MAX_DRAWDOWN_PERCENT=15
POSITION_CONCENTRATION_LIMIT=30  # percent of account
KELLY_CRITERION_FRACTION=0.25

# Position Sizing
RISK_PER_TRADE=2  # percent
BASE_LOT_SIZE=0.01

# Trading Hours
TRADING_SESSION=all  # or london, newyork, tokyo, sydney
SKIP_NEWS_EVENTS=true

# ==================== MACHINE LEARNING ====================
# Model Retraining
MODEL_RETRAIN_FREQUENCY=weekly  # or daily, monthly
LSTM_LOOKBACK_PERIODS=60
CONFIDENCE_THRESHOLD=0.65

# Feature Engineering
USE_TECHNICAL_INDICATORS=true
USE_SENTIMENT_ANALYSIS=true
USE_ECONOMIC_CALENDAR=true
USE_MARKET_MICROSTRUCTURE=true

# ==================== SYSTEM CONFIG ====================
# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH=./logs/hopefx_trading.log

# Backtesting
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_INITIAL_CAPITAL=10000
BACKTEST_COMMISSION=0.0001

# Performance
MAX_WORKERS=4
ASYNC_BUFFER_SIZE=1000
WEBSOCKET_PING_INTERVAL=30

# ==================== SECURITY (REQUIRED) ====================
# Master encryption key for securing API credentials (minimum 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CONFIG_ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# Salt for PBKDF2 key derivation (hex-encoded, recommended for new installations)
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
CONFIG_SALT=your_32_character_hex_salt_here

# Application environment (development, staging, production)
# IMPORTANT: Set to "production" in production environments
APP_ENV=development

# Security Settings
API_KEY_ENCRYPTION=true
ENCRYPT_SENSITIVE_DATA=true
SESSION_TIMEOUT_MINUTES=120
ENABLE_SECURITY_MONITORING=true
LOG_SANITIZATION_ENABLED=true
CREDENTIAL_ROTATION_DAYS=90

# ==================== DEPLOYMENT ====================
# Flask/FastAPI
API_HOST=0.0.0.0
API_PORT=5000
API_WORKERS=4

# Environment
ENVIRONMENT=development  # or production, staging
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,https://yourfrontend.com

# ==================== CLOUD DEPLOYMENT ====================
# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# GCP Configuration
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_CREDENTIALS_PATH=./credentials/gcp-credentials.json

# Docker
DOCKER_REGISTRY=your_docker_registry
DOCKER_IMAGE_TAG=latest

# ==================== MONITORING ====================
# Prometheus Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# DataDog
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_ENABLED=false

# ==================== ADVANCED ====================
# Portfolio Management
MULTI_ACCOUNT_MODE=false
FUND_MANAGER_MODE=false
PERFORMANCE_FEE_PERCENT=20

# Strategy Parameters
USE_SMC_ANALYSIS=true
USE_DARK_POOL_DETECTION=true
USE_INSTITUTIONAL_FLOW=true
USE_GEOPOLITICAL_SIGNALS=true  # World Monitor integration for XAU/USD

# Market Microstructure
MONITOR_ORDER_IMBALANCE=true
DETECT_SPOOFING_PATTERNS=true
ANALYZE_BLOCK_TRADES=true
# ==================== FEATURE FLAGS ====================
# Controls which platform features are active at runtime.
# See FEATURES.md for full documentation.
# Set to "false" / "0" / "no" / "off" to disable; any other value enables.

# -- Core Trading --
FEATURE_STRATEGY_MANAGER=true
FEATURE_PAPER_TRADING=true
FEATURE_LIVE_TRADING=false          # Requires explicit opt-in for safety
FEATURE_RISK_MANAGER=true

# -- Strategies --
FEATURE_STRATEGY_MA_CROSSOVER=true
FEATURE_STRATEGY_EMA_CROSSOVER=true
FEATURE_STRATEGY_BOLLINGER=true
FEATURE_STRATEGY_BREAKOUT=true
FEATURE_STRATEGY_MACD=true
FEATURE_STRATEGY_RSI=true
FEATURE_STRATEGY_SMC_ICT=true
FEATURE_STRATEGY_MEAN_REVERSION=true
FEATURE_STRATEGY_STOCHASTIC=true
FEATURE_STRATEGY_BRAIN=true

# -- Analysis & Order Flow --
FEATURE_ORDER_FLOW_ANALYSIS=true
FEATURE_ORDER_FLOW_ADVANCED=true
FEATURE_INSTITUTIONAL_FLOW=true
FEATURE_ORDER_FLOW_DASHBOARD=true
FEATURE_MARKET_ANALYSIS=true
FEATURE_MARKET_SCANNER=true
FEATURE_CANDLESTICK_PATTERNS=true
FEATURE_DARK_POOL_DETECTION=true

# -- Data Feeds --
FEATURE_TIME_AND_SALES=true
FEATURE_DEPTH_OF_MARKET=true
FEATURE_MARKET_DATA_STREAMING=true

# -- News & Sentiment --
FEATURE_NEWS_SENTIMENT=true
FEATURE_ECONOMIC_CALENDAR=true
FEATURE_GEOPOLITICAL_RISK=true

# -- Machine Learning --
FEATURE_ML_PREDICTIONS=false        # EXPERIMENTAL — see "Experimental / Unreleased" section below
FEATURE_ML_FEATURE_ENGINEERING=true

# -- Charting --
FEATURE_CHART_ENGINE=true
FEATURE_DRAWING_TOOLS=true

# -- Backtesting --
FEATURE_BACKTESTING=true
FEATURE_WALK_FORWARD=true

# -- Broker Connectors --
FEATURE_BROKER_OANDA=true
FEATURE_BROKER_ALPACA=true
FEATURE_BROKER_BINANCE=true
FEATURE_BROKER_MT5=true
FEATURE_BROKER_INTERACTIVE_BROKERS=true

# -- Social & Copy Trading --
FEATURE_SOCIAL_TRADING=true
FEATURE_COPY_TRADING=true

# -- Monetisation --
FEATURE_SUBSCRIPTIONS=true
FEATURE_WHITE_LABEL=true
FEATURE_ENTERPRISE=true
FEATURE_PAYMENTS=true

# -- Mobile --
FEATURE_MOBILE_API=true
FEATURE_PUSH_NOTIFICATIONS=true

# -- Admin & Monitoring --
FEATURE_ADMIN_DASHBOARD=true
FEATURE_ANALYTICS=true

# -- Experimental / Unreleased (off by default) --
# These modules are fully implemented but gated behind feature flags.
# Set any flag to `true` in this file (or export the env-var) to enable it.
# Restart the app after changing — each enabled module registers its own
# FastAPI routes at startup (/docs will show them once enabled).
#
# | Flag                    | Routes registered when enabled              |
# |-------------------------|---------------------------------------------|
# | FEATURE_RESEARCH        | /api/research/*   (notebooks, templates)    |
# | FEATURE_EXPLAINABILITY  | /api/explainability/*  (SHAP/LIME explain)  |
# | FEATURE_TRANSPARENCY    | /api/transparency/*  (execution audit)      |
# | FEATURE_TEAMS           | /api/teams/*  (RBAC, invitations)           |
# | FEATURE_NOCODE          | /api/nocode/*  (visual strategy builder)    |
# | FEATURE_REPLAY          | /api/replay/*  (tick-level market replay)   |
# | FEATURE_ML_PREDICTIONS  | /api/ml/*  (LSTM/Transformer predictions)   |
#
FEATURE_RESEARCH=false          # Quantitative alpha research tooling — WIP
FEATURE_EXPLAINABILITY=false    # SHAP/LIME explainability for ML decisions — WIP
FEATURE_TRANSPARENCY=false      # Regulatory execution-quality audit reports — WIP
FEATURE_TEAMS=false             # Multi-user workspaces and RBAC — WIP
FEATURE_NOCODE=false            # Visual no-code strategy builder — WIP
FEATURE_REPLAY=false            # Tick-level historical market replay — WIP
FEATURE_ML_PREDICTIONS=false    # LSTM/Transformer price-direction predictions — model training pipeline pending
